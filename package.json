{
  "name": "sanic-run",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:e2e": "tsc -b && vite build --mode e2e --outDir dist-e2e",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:production": "npm run build && playwright test --config=playwright.production.config.ts",
    "check": "npm run test && npm run build && npm run test:e2e && npm run test:e2e:production"
  },
  "dependencies": {
    "@fontsource/bangers": "5.2.8",
    "@fontsource/press-start-2p": "5.2.7",
    "@fontsource/space-mono": "5.2.9",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@gltf-transform/cli": "4.4.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/three": "0.185.1",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
